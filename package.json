    "agents/mira-new",
    "agents/mira-animator",
    "agents/mira-brand-template",
    "agents/mira-size-animator",
    "agents/mira-animated-metaphor",
    "agents/mira-3d",
    "agents/mira-qrcode",
    "agents/mira-image",
    "agents/mira-svg-morph",
    "agents/mira-icon-morph",
    "agents/mira-svg-animator",
    "agents/mira-squared",
    "agents/mira-vertical",
    "agents/mira-thirds",
    "agents/mira-transition-dissolve",
    "agents/mira-builder/SKILL.md",
    "agents/mira-chart",
    "agents/mira-builder/templates",
    "agents/mira-builder/video_lista.md",
    "agents/mira-copywriter",
    "agents/mira-extract",
    "agents/mira-get-videos",
    "agents/mira-image-prompt",
    "agents/mira-image-template",
    "agents/mira-img-animator",
