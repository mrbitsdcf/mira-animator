    "agents/mira-references",
    "agents/mira-validator",
    "agents/mira-visuals",
    "bin/",
    "lib/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "author": "sandeco",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandeco/mira-animator.git"
  },
